{
  "name": "akilli-garson-api",
  "version": "0.1.0",
  "description": "Akıllı Garson — Production NestJS API",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:integration:coverage": "jest --config jest.integration.config.js --runInBand --coverage",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.0.11",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.0.6",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/client": "^6.5.0",
    "bullmq": "^5.41.9",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "nestjs-pino": "^4.3.1",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.2",
    "@nestjs/testing": "^11.1.27",
    "@testcontainers/postgresql": "^10.18.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "jest": "^30.4.2",
    "pg": "^8.22.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.5.0",
    "testcontainers": "^10.18.0",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.13",
    "typescript": "^5.8.2"
  }
}
